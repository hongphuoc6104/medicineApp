# MedicineApp Server — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://medicineapp:medicineapp_dev_2026@localhost:5432/medicineapp

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Python FastAPI (AI Pipeline)
PYTHON_API_URL=http://localhost:8000

# External APIs
DDI_API_BASE=https://ddi.lab.io.vn/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# File Upload
MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=info
