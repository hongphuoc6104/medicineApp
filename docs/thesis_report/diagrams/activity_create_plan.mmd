flowchart LR
    START(["Bắt đầu"])
    A["Quét đơn thuốc\nvà nhận kết quả"]
    B{"Cần chỉnh\nsửa thuốc?"}
    C["Chỉnh sửa\ndanh sách thuốc"]
    D["Chọn ngày bắt đầu\nvà số ngày dùng"]
    E["Chọn khung giờ\nuống thuốc"]
    F["Nhập số viên\nmỗi khung giờ"]
    G["Lưu kế hoạch\nlên máy chủ"]
    H["Thiết lập thông báo\nnhắc uống thuốc"]
    END(["Kết thúc"])

    START --> A --> B
    B -->|"Có"| C --> D
    B -->|"Không"| D
    D --> E --> F --> G --> H --> END

    classDef terminator fill:#2457a5,stroke:#2457a5,color:#ffffff
    classDef step fill:#f0f7f4,stroke:#2d7a46,stroke-width:1.3px,color:#111
    classDef decision fill:#fff8e1,stroke:#b7791f,stroke-width:1.3px,color:#111

    class START,END terminator
    class A,C,D,E,F,G,H step
    class B decision
