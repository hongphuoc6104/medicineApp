flowchart TD
    START(["●  Bắt đầu"])
    A["Người dùng quét đơn thuốc\nvà nhận kết quả nhận diện"]
    B{"Cần chỉnh sửa\ndanh sách thuốc?"}
    C["Sửa, thêm hoặc xóa thuốc\ntheo ý người dùng"]
    D["Chọn ngày bắt đầu\nvà số ngày dùng thuốc"]
    E["Chọn khung giờ uống thuốc\n(sáng / trưa / tối / khuya)"]
    F["Nhập số viên cho mỗi\nthuốc ở từng khung giờ"]
    G["Lưu kế hoạch lên máy chủ"]
    H["Thiết lập thông báo\nnhắc uống thuốc cục bộ"]
    END(["⬤  Kết thúc"])

    START --> A --> B
    B -->|"Có"| C --> D
    B -->|"Không"| D
    D --> E --> F --> G --> H --> END

    classDef terminator fill:#2457a5,stroke:#2457a5,color:#ffffff,rx:20
    classDef step fill:#f0f7f4,stroke:#2d7a46,stroke-width:1.3px,color:#111
    classDef decision fill:#fff8e1,stroke:#b7791f,stroke-width:1.3px,color:#111

    class START,END terminator
    class A,C,D,E,F,G,H step
    class B decision
