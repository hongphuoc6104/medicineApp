erDiagram
    USERS ||--o{ SCANS : "tạo"
    USERS ||--o{ SCAN_SESSIONS : "tạo"
    USERS ||--o{ PRESCRIPTION_PLANS : "sở hữu"

    PRESCRIPTION_PLANS ||--o{ PRESCRIPTION_PLAN_DRUGS : "gồm"
    PRESCRIPTION_PLANS ||--o{ PRESCRIPTION_PLAN_SLOTS : "gồm"
    PRESCRIPTION_PLANS ||--o{ PRESCRIPTION_PLAN_LOGS : "ghi nhật ký"

    PRESCRIPTION_PLAN_SLOTS ||--o{ PRESCRIPTION_PLAN_SLOT_DRUGS : "chứa"
    PRESCRIPTION_PLAN_DRUGS ||--o{ PRESCRIPTION_PLAN_SLOT_DRUGS : "được gán"

    USERS {
        uuid id PK
        varchar email UK
        varchar name
        timestamptz created_at
    }

    SCANS {
        uuid id PK
        uuid user_id FK
        uuid session_id FK
        varchar quality_status
        integer drug_count
        jsonb result
        timestamptz scanned_at
    }

    SCAN_SESSIONS {
        uuid id PK
        uuid user_id FK
        varchar status
        boolean converged
        jsonb merged_result
        timestamptz created_at
    }

    PRESCRIPTION_PLANS {
        uuid id PK
        uuid user_id FK
        varchar title
        date start_date
        date end_date
        integer total_days
        boolean is_active
    }

    PRESCRIPTION_PLAN_DRUGS {
        uuid id PK
        uuid plan_id FK
        varchar drug_name
        varchar dosage
        integer sort_order
    }

    PRESCRIPTION_PLAN_SLOTS {
        uuid id PK
        uuid plan_id FK
        varchar slot_time
        integer sort_order
    }

    PRESCRIPTION_PLAN_SLOT_DRUGS {
        uuid id PK
        uuid slot_id FK
        uuid drug_id FK
        integer pills
    }

    PRESCRIPTION_PLAN_LOGS {
        uuid id PK
        uuid plan_id FK
        varchar occurrence_id UK
        varchar slot_time
        timestamptz scheduled_time
        varchar status
        timestamptz logged_at
    }
