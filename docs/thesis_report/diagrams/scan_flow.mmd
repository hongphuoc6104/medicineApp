flowchart TD
    A["Ảnh đơn thuốc đầu vào"]
    B["Bước 1: Phát hiện và cắt vùng đơn thuốc\n(YOLO Detect)"]
    C["Bước 2: Tiền xử lý ảnh\n(Chỉnh nghiêng · Hiệu chỉnh hướng AI)"]
    QG{"Kiểm tra chất lượng ảnh"}
    REJ["Từ chối — Yêu cầu chụp lại"]
    D["Bước 3: Nhận dạng ký tự quang học\n(PaddleOCR + VietOCR)"]
    E["Bước 4: Trích xuất tên thuốc\n(PhoBERT NER)"]
    F["Bước 5: Tra cứu và chuẩn hóa tên thuốc\n(Cơ sở dữ liệu 9.284 thuốc)"]
    G["Danh sách thuốc\n(để người dùng rà soát)"]
    H["Lập lịch dùng thuốc"]

    A --> B --> C --> QG
    QG -->|"Đạt yêu cầu"| D
    QG -->|"Quá mờ / chói"| REJ
    D --> E --> F --> G --> H

    classDef mainStep fill:#f0f7f4,stroke:#2d7a46,stroke-width:1.4px,color:#111
    classDef decision fill:#fff8e1,stroke:#b7791f,stroke-width:1.4px,color:#111
    classDef reject fill:#fff3f3,stroke:#c53030,stroke-width:1.2px,color:#c53030
